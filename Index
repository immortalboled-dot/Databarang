<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Manajemen Toko & Gudang V5 - Production Ready</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    
    <style>
        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: rgba(0, 0, 0, 0.1);
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(156, 163, 175, 0.3);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(156, 163, 175, 0.5);
        }
    </style>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen font-sans transition-colors duration-300" id="bodyApp">

    <div id="authContainer" class="fixed inset-0 bg-gray-950 flex items-center justify-center p-4 z-50">
        <div id="loginBox" class="bg-gray-800 border border-gray-700 p-8 rounded-2xl w-full max-w-md shadow-2xl space-y-6">
            <div class="text-center">
                <h1 class="text-2xl font-bold tracking-wider text-emerald-400 flex justify-center items-center gap-2">
                    <i data-lucide="store"></i> TOKO & GUDANG
                </h1>
                <p class="text-gray-400 text-sm mt-1">Silakan masuk untuk mengakses sistem aplikasi</p>
            </div>
            <div class="space-y-4">
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Nama Pengguna / Karyawan</label>
                    <input type="text" id="loginNama" placeholder="Ketik nama terdaftar..." class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-emerald-500 text-white text-sm">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Kata Sandi</label>
                    <input type="password" id="loginSandi" placeholder="••••••••" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-emerald-500 text-white text-sm">
                </div>
                <button onclick="prosesLogin()" class="w-full bg-emerald-500 hover:bg-emerald-600 py-2.5 rounded-xl font-bold shadow-lg text-gray-950 transition-all cursor-pointer text-sm">
                    Masuk ke Sistem
                </button>
                <div class="text-center pt-2">
                    <p class="text-xs text-gray-400">Belum punya akun? <button onclick="toggleAuthBox(true)" class="text-emerald-400 font-semibold hover:underline cursor-pointer">Daftar Karyawan Baru</button></p>
                </div>
            </div>
        </div>

        <div id="daftarBox" class="bg-gray-800 border border-gray-700 p-8 rounded-2xl w-full max-w-md shadow-2xl space-y-5 hidden">
            <div class="text-center">
                <h1 class="text-xl font-bold tracking-wider text-emerald-400 flex justify-center items-center gap-2">
                    <i data-lucide="user-plus"></i> DAFTAR KARYAWAN
                </h1>
                <p class="text-gray-400 text-sm mt-1">Buat akun akses kasir & gudang baru</p>
            </div>
            <div class="space-y-3.5">
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Nama Lengkap Karyawan</label>
                    <input type="text" id="regNama" placeholder="Contoh: Budi Santoso" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-emerald-500 text-white text-sm">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Shift Kerja</label>
                    <select id="regShift" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-emerald-500 text-white text-sm">
                        <option value="Pagi (07:00 - 15:00)">Pagi (07:00 - 15:00)</option>
                        <option value="Siang (15:00 - 23:00)">Siang (15:00 - 23:00)</option>
                        <option value="Malam (23:00 - 07:00)">Malam (23:00 - 07:00)</option>
                    </select>
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Kata Sandi Baru</label>
                    <input type="password" id="regSandi" placeholder="Buat kata sandi aman..." class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-emerald-500 text-white text-sm">
                </div>
                <div>
                    <label class="text-xs text-amber-400 font-semibold block mb-1">Kode Rahasia Programmer (Kunci Sistem)</label>
                    <input type="password" id="regKodeKhusus" placeholder="Masukkan kode otorisasi dev..." class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2.5 focus:outline-none focus:border-amber-500 text-white text-sm">
                </div>
                <button onclick="prosesDaftar()" class="w-full bg-amber-500 hover:bg-amber-600 py-2.5 rounded-xl font-bold shadow-lg text-gray-950 transition-all cursor-pointer text-sm">
                    Daftarkan Akun
                </button>
                <div class="text-center pt-2">
                    <p class="text-xs text-gray-400">Sudah punya akun? <button onclick="toggleAuthBox(false)" class="text-emerald-400 font-semibold hover:underline cursor-pointer">Login disini</button></p>
                </div>
            </div>
        </div>
    </div>

    <div class="flex h-screen overflow-hidden">
        
        <div class="w-64 bg-gray-800 border-r border-gray-700 flex flex-col justify-between transition-colors duration-300" id="sidebarContainer">
            <div class="p-5">
                <h1 class="text-xl font-bold tracking-wider text-emerald-400 flex items-center gap-2">
                    <i data-lucide="store"></i> TOKO & GUDANG
                </h1>
                
                <div class="mt-4 p-3 bg-gray-900/60 rounded-xl border border-gray-700/50 flex flex-col gap-1">
                    <span class="text-[10px] uppercase font-bold tracking-widest text-gray-400">User Login</span>
                    <span id="userAktifNama" class="font-bold text-sm text-white truncate">-</span>
                    <span id="userAktifShift" class="text-xs text-emerald-400 truncate">-</span>
                </div>

                <nav class="mt-6 space-y-2">
                    <button onclick="switchTab('gudang')" id="btn-gudang" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg bg-emerald-600 text-white font-medium transition-all cursor-pointer">
                        <i data-lucide="warehouse"></i> Gudang Belakang
                    </button>
                    <button onclick="switchTab('kasir')" id="btn-kasir" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all cursor-pointer">
                        <i data-lucide="shopping-cart"></i> Kasir / Penjualan
                    </button>
                    <button onclick="switchTab('history')" id="btn-history" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all cursor-pointer">
                        <i data-lucide="history"></i> History Penjualan
                    </button>
                    <button onclick="switchTab('keuangan')" id="btn-keuangan" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all cursor-pointer">
                        <i data-lucide="wallet"></i> Manajemen Keuangan
                    </button>
                    <button onclick="switchTab('setting')" id="btn-setting" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all cursor-pointer">
                        <i data-lucide="settings"></i> Pengaturan Tema
                    </button>
                </nav>
            </div>
            
            <div class="flex flex-col">
                <div class="p-4 bg-gray-900/40 border-t border-gray-700 max-h-40 overflow-y-auto" id="sidebarNotif">
                    <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider block mb-2">Notifikasi Sistem</span>
                    <div id="notifList" class="space-y-2 text-xs"></div>
                </div>
                <div class="p-4 border-t border-gray-700 bg-gray-900/20">
                    <button onclick="prosesLogout()" class="w-full bg-red-600/20 hover:bg-red-600 text-red-200 border border-red-500/30 font-semibold py-2 rounded-lg text-xs flex justify-center items-center gap-2 cursor-pointer transition-all">
                        <i data-lucide="log-out" class="w-3.5 h-3.5"></i> Logout Sesi
                    </button>
                </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col overflow-y-auto p-8">
            
            <div id="tab-gudang" class="tab-content space-y-6">
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                    <div>
                        <h2 class="text-2xl font-bold">Gudang Belakang (Stok Produk)</h2>
                        <p class="text-gray-400 text-sm">Kelola stok gudang serta download/kirim berkas data barang.</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <button onclick="exportGudangExcel()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="file-spreadsheet"></i> Export Excel
                        </button>
                        <button onclick="kirimGudangWA()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="share-2"></i> Kirim WA
                        </button>
                        <button onclick="openModal('tambah')" class="bg-emerald-500 hover:bg-emerald-600 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow-lg transition-all text-gray-950">
                            <i data-lucide="plus-circle"></i> Tambah Barang
                        </button>
                    </div>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 flex items-center gap-3 data-box transition-colors duration-300">
                    <i data-lucide="search" class="text-gray-400"></i>
                    <input type="text" id="searchGudang" oninput="renderGudang()" placeholder="Cari berdasarkan nama produk di gudang..." class="bg-transparent w-full focus:outline-none text-white">
                </div>

                <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-md data-box transition-colors duration-300">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[800px]">
                            <thead>
                                <tr class="bg-gray-700/50 text-gray-300 text-sm border-b border-gray-700">
                                    <th class="p-4">Nama Barang</th>
                                    <th class="p-4">Stok Toko/Kasir</th>
                                    <th class="p-4">Harga Satuan</th>
                                    <th class="p-4 text-emerald-400">Total Harga</th>
                                    <th class="p-4">Tgl Masuk</th>
                                    <th class="p-4">Tgl Expired</th>
                                    <th class="p-4">Status di Kasir</th>
                                    <th class="p-4 text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="tabelGudangBody" class="divide-y divide-gray-700 text-sm"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="tab-kasir" class="tab-content hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold">Kasir Penjualan & Pengambilan Barang</h2>
                    <p class="text-gray-400 text-sm">Barang dari gudang hanya akan muncul di etalase penjualan kiri setelah diambil di menu kanan.</p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 bg-gray-800 p-6 rounded-xl border border-gray-700 space-y-4 data-box transition-colors duration-300">
                        <span class="text-xs font-bold text-emerald-400 uppercase tracking-widest block">🔍 1. Pencarian Barang Kasir (Siap Jual)</span>
                        <div class="bg-gray-700 p-3 rounded-lg flex items-center gap-3">
                            <i data-lucide="search" class="text-gray-400"></i>
                            <input type="text" id="searchKasir" oninput="renderKasirProduk()" placeholder="Ketik nama produk yang sudah diambil dari gudang..." class="bg-transparent w-full focus:outline-none text-white">
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[440px] overflow-y-auto pr-2" id="kasirProdukGrid"></div>
                    </div>

                    <div class="space-y-6">
                        <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 space-y-3 shadow-xl data-box transition-colors duration-300">
                            <span class="text-xs font-bold text-amber-400 uppercase tracking-widest block">📦 2. Pencarian Barang Gudang (Ambil Stok)</span>
                            <div class="bg-gray-700 p-2 rounded-lg flex items-center gap-2 text-xs">
                                <i data-lucide="search" class="text-gray-400 w-4 h-4"></i>
                                <input type="text" id="searchAmbilGudang" oninput="renderAmbilGudangList()" placeholder="Cari barang di gudang untuk ditarik..." class="bg-transparent w-full focus:outline-none text-white">
                            </div>
                            <div class="max-h-[150px] overflow-y-auto space-y-2 text-xs" id="ambilGudangResultList"></div>
                        </div>

                        <div class="bg-gray-800 p-5 rounded-xl border border-gray-700 flex flex-col justify-between min-h-[410px] shadow-xl data-box transition-colors duration-300">
                            <div>
                                <h3 class="font-bold text-base border-b border-gray-700 pb-2 mb-3 flex items-center gap-2">
                                    <i data-lucide="shopping-bag" class="text-emerald-400"></i> Keranjang Belanja
                                </h3>
                                <div class="space-y-3 max-h-[180px] overflow-y-auto pr-2" id="keranjangList"></div>
                            </div>
                            
                            <div class="border-t border-gray-700 pt-3 space-y-3 text-xs mt-4">
                                <div class="flex justify-between items-center text-sm font-bold">
                                    <span>Total Tagihan:</span>
                                    <span class="text-emerald-400 text-base" id="totalTagihan">Rp 0</span>
                                </div>
                                <div class="space-y-1">
                                    <label class="text-gray-400 block text-[11px]">Uang Tunai Diterima (Rp):</label>
                                    <input type="number" id="uangBayarInput" oninput="hitungKembalian()" placeholder="Contoh: 50000" class="w-full bg-gray-700 border border-gray-600 rounded p-2 focus:outline-none focus:border-emerald-500 text-white font-bold">
                                </div>
                                <div class="flex justify-between items-center bg-gray-900/40 p-2.5 rounded border border-gray-700">
                                    <span class="text-gray-400 font-medium">Uang Kembalian:</span>
                                    <span class="text-amber-400 font-bold text-sm" id="uangKembalianText">Rp 0</span>
                                </div>
                                <button onclick="bayarTransaksi()" class="w-full bg-emerald-500 hover:bg-emerald-600 py-2.5 rounded-xl font-bold shadow-lg transition-all cursor-pointer text-center text-sm text-gray-950">
                                    Selesaikan Transaksi
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div id="tab-history" class="tab-content hidden space-y-6">
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                    <div>
                        <h2 class="text-2xl font-bold">Riwayat Penjualan (History)</h2>
                        <p class="text-gray-400 text-sm">Laporan riwayat transaksi keluar barang yang terjual.</p>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="exportToExcel()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="file-spreadsheet"></i> Export Excel History
                        </button>
                        <button onclick="kirimWhatsApp()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="share-2"></i> Kirim WA History
                        </button>
                    </div>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 flex items-center gap-3 data-box transition-colors duration-300">
                    <i data-lucide="search" class="text-gray-400"></i>
                    <input type="text" id="searchHistory" oninput="renderHistory()" placeholder="Cari data history berdasarkan nama barang atau ID Transaksi..." class="bg-transparent w-full focus:outline-none text-white">
                </div>

                <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-md data-box transition-colors duration-300">
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse min-w-[700px]">
                            <thead>
                                <tr class="bg-gray-700/50 text-gray-300 text-sm border-b border-gray-700">
                                    <th class="p-4">Waktu Transaksi</th>
                                    <th class="p-4">ID Transaksi</th>
                                    <th class="p-4">Nama Barang</th>
                                    <th class="p-4">Jumlah Terjual</th>
                                    <th class="p-4">Total Pendapatan</th>
                                    <th class="p-4 text-center">Aksi</th>
                                </tr>
                            </thead>
                            <tbody id="tabelHistoryBody" class="divide-y divide-gray-700 text-sm"></tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="tab-keuangan" class="tab-content hidden space-y-6">
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                    <div>
                        <h2 class="text-2xl font-bold">Manajemen Keuangan & Aset</h2>
                        <p class="text-gray-400 text-sm">Pantau kas fisik, omset penjualan, dan total nominal aset barang.</p>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="exportKeuanganExcel()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="file-spreadsheet"></i> Export Keuangan
                        </button>
                        <button onclick="kirimKeuanganWA()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow transition-all">
                            <i data-lucide="share-2"></i> Kirim WA Keuangan
                        </button>
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-6">
                    <div class="bg-gradient-to-br from-emerald-600 to-teal-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Saldo Kas Toko</span>
                            <i data-lucide="wallet" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-2xl font-extrabold tracking-tight" id="dompetSaldo">Rp 2.500.000</h3>
                    </div>
                    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Omset Penjualan</span>
                            <i data-lucide="trending-up" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-2xl font-extrabold tracking-tight" id="dompetOmset">Rp 0</h3>
                    </div>
                    <div class="bg-gradient-to-br from-violet-600 to-purple-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Uang di Barang (Aset)</span>
                            <i data-lucide="boxes" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-2xl font-extrabold tracking-tight text-yellow-300" id="dompetAsetBarang">Rp 0</h3>
                    </div>
                    <div class="bg-gradient-to-br from-amber-600 to-orange-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Macam Produk</span>
                            <i data-lucide="box" class="w-5 h-5"></i>
                        </div>
                        <h3 class="text-2xl font-extrabold tracking-tight" id="dompetProduk">0 SKU</h3>
                    </div>
                </div>

                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 space-y-4 data-box transition-colors duration-300">
                    <h3 class="font-bold text-lg">Sesuaikan Modal Kas Manual</h3>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <input type="number" id="inputModalBaru" placeholder="Masukkan jumlah uang/modal awal..." class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 w-full sm:w-72 text-white focus:outline-none focus:border-emerald-500">
                        <button onclick="setModalManual()" class="bg-emerald-500 hover:bg-emerald-600 px-6 py-2 rounded-lg font-semibold cursor-pointer text-gray-950 transition-all">Simpan Uang Kas</button>
                    </div>
                </div>
            </div>

            <div id="tab-setting" class="tab-content hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold">Pengaturan Warna Background Kustom</h2>
                    <p class="text-gray-400 text-sm">Pilih warna sesuka Anda menggunakan pemilih warna interaktif dibawah ini.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 space-y-4 data-box transition-colors duration-300">
                        <h3 class="font-bold text-base text-emerald-400 flex items-center gap-2">
                            <i data-lucide="palette"></i> Atur Warna Latar Belakang Anda sendiri:
                        </h3>
                        <div class="flex flex-wrap items-center gap-4">
                            <div>
                                <label class="text-xs text-gray-400 block mb-1">Pilih Warna Utama (Background):</label>
                                <input type="color" id="customBgColor" value="#111827" oninput="aplikasikanWarnaKustom()" class="w-24 h-12 rounded cursor-pointer bg-transparent border border-gray-600 p-1">
                            </div>
                            <div>
                                <label class="text-xs text-gray-400 block mb-1">Pilih Warna Kotak Konten:</label>
                                <input type="color" id="customBoxColor" value="#1f2937" oninput="aplikasikanWarnaKustom()" class="w-24 h-12 rounded cursor-pointer bg-transparent border border-gray-600 p-1">
                            </div>
                        </div>
                    </div>

                    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 grid grid-cols-2 gap-3 data-box transition-colors duration-300">
                        <button onclick="gantiTemaPreset('#0f172a', '#1e293b')" class="p-3 border border-gray-700 rounded bg-slate-900 text-xs text-left cursor-pointer hover:border-blue-500 transition-all">
                            <span class="font-bold block text-blue-400">Deep Slate Blue</span>
                        </button>
                        <button onclick="gantiTemaPreset('#09090b', '#18181b')" class="p-3 border border-gray-700 rounded bg-zinc-950 text-xs text-left cursor-pointer hover:border-gray-500 transition-all">
                            <span class="font-bold block text-gray-400">AMOLED Pitch Black</span>
                        </button>
                        <button onclick="gantiTemaPreset('#022c22', '#064e3b')" class="p-3 border border-gray-700 rounded bg-emerald-950 text-xs text-left cursor-pointer hover:border-emerald-500 transition-all">
                            <span class="font-bold block text-emerald-400">Forest Dark Green</span>
                        </button>
                        <button onclick="gantiTemaPreset('#111827', '#1f2937')" class="p-3 border border-gray-700 rounded bg-gray-900 text-xs text-left cursor-pointer hover:border-white transition-all">
                            <span class="font-bold block text-white">Default Midnight</span>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <div id="formModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50 animate-fade-in">
        <div class="bg-gray-800 border border-gray-700 rounded-2xl w-full max-w-lg p-6 shadow-2xl space-y-4 data-box transition-colors duration-300">
            <h3 id="modalTitle" class="text-xl font-bold text-emerald-400">Tambah Barang Baru</h3>
            <input type="hidden" id="editIndex">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Nama Barang</label>
                    <input type="text" id="formNama" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500 text-white">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Jumlah Awal Gudang</label>
                    <input type="number" id="formStok" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500 text-white">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Harga Jual (Rp)</label>
                    <input type="number" id="formHarga" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500 text-white">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Tanggal Masuk</label>
                    <input type="date" id="formTglMasuk" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500 text-white">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Tanggal Expiry</label>
                    <input type="date" id="formTglExp" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500 text-white">
                </div>
            </div>

            <div class="flex justify-end gap-2 pt-4 border-t border-gray-700">
                <button onclick="closeModal()" class="px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 font-semibold cursor-pointer text-sm transition-all">Batal</button>
                <button onclick="simpanBarang()" class="px-4 py-2 rounded-lg bg-emerald-500 hover:bg-emerald-600 font-semibold cursor-pointer text-sm text-gray-950 transition-all">Simpan Data</button>
            </div>
        </div>
    </div>

    <script>
        // --- DATA STATE UTAMA ---
        // Kunci Rahasia Sistem yang diatur oleh Programmer
        const KODE_RAHASIA_PROGRAMMER = "RAHASIA2026"; 

        // Database Karyawan Lokal Default (Untuk testing awal)
        let databaseKaryawan = [
            { nama: "Admin", sandi: "admin123", shift: "Pagi (07:00 - 15:00)" }
        ];

        let userSesiAktif = null; // Menyimpan data akun yang sedang login

        let dataBarang = [
            { nama: "Susu UHT Frisian", stok: 0, harga: 6500, tglMasuk: "2026-01-01", tglExp: "2026-07-10", keluar: 0, pernahAmbil: false },
            { nama: "Mie Instan Goreng", stok: 0, harga: 3500, tglMasuk: "2026-02-15", tglExp: "2027-05-20", keluar: 0, pernahAmbil: false },
            { nama: "Roti Tawar Kupas", stok: 0, harga: 15000, tglMasuk: "2026-03-01", tglExp: "2026-07-06", keluar: 0, pernahAmbil: false }
        ];

        let historyPenjualan = [];
        let uangKas = 2500000;
        let omsetPenjualan = 0;
        let keranjang = [];
        let totalAsetSekarang = 0;
        let totalTagihanGlobal = 0;

        window.onload = function() {
            lucide.createIcons();
            periksaSesiLogin();
        }

        // --- SISTEM AUTENTIKASI (LOGIN, DAFTAR, LOGOUT) ---
        function toggleAuthBox(keDaftar) {
            if(keDaftar) {
                document.getElementById('loginBox').classList.add('hidden');
                document.getElementById('daftarBox').classList.remove('hidden');
            } else {
                document.getElementById('daftarBox').classList.add('hidden');
                document.getElementById('loginBox').classList.remove('hidden');
            }
        }

        function prosesDaftar() {
            const nama = document.getElementById('regNama').value.trim();
            const shift = document.getElementById('regShift').value;
            const sandi = document.getElementById('regSandi').value;
            const kodeKhusus = document.getElementById('regKodeKhusus').value;

            if(!nama || !sandi || !kodeKhusus) {
                return alert("Mohon isi seluruh formulir pendaftaran!");
            }

            // Validasi kunci rahasia programmer
            if(kodeKhusus !== KODE_RAHASIA_PROGRAMMER) {
                return alert("Gagal! Kode Rahasia Programmer salah/tidak sah. Hubungi pihak developer.");
            }

            // Periksa jika username sudah ada
            const sudahAda = databaseKaryawan.find(u => u.nama.toLowerCase() === nama.toLowerCase());
            if(sudahAda) return alert("Nama Karyawan tersebut sudah terdaftar di sistem!");

            // Simpan ke db lokal array
            databaseKaryawan.push({ nama, sandi, shift });
            alert(`Pendaftaran Berhasil! Akun untuk [${nama}] telah aktif. Silakan login.`);
            
            // Bersihkan form & beralih ke login
            document.getElementById('regNama').value = '';
            document.getElementById('regSandi').value = '';
            document.getElementById('regKodeKhusus').value = '';
            toggleAuthBox(false);
        }

        function prosesLogin() {
            const nama = document.getElementById('loginNama').value.trim();
            const sandi = document.getElementById('loginSandi').value;

            const akunCocok = databaseKaryawan.find(u => u.nama.toLowerCase() === nama.toLowerCase() && u.sandi === sandi);

            if(akunCocok) {
                userSesiAktif = akunCocok;
                alert(`Selamat Datang, ${userSesiAktif.nama}! Sesi shift Anda telah dimulai.`);
                
                document.getElementById('loginNama').value = '';
                document.getElementById('loginSandi').value = '';
                periksaSesiLogin();
            } else {
                alert("Login gagal! Nama pengguna atau kata sandi Anda salah.");
            }
        }

        function prosesLogout() {
            if(confirm("Apakah Anda yakin ingin keluar dari sistem? Keranjang belanja belum tersimpan mungkin akan hilang.")) {
                userSesiAktif = null;
                keranjang = [];
                alert("Anda berhasil keluar dari sistem.");
                periksaSesiLogin();
            }
        }

        function periksaSesiLogin() {
            const authContainer = document.getElementById('authContainer');
            if(userSesiAktif) {
                // Sembunyikan layar login jika ada sesi aktif
                authContainer.classList.add('hidden');
                
                // Set data tampilan profil di sidebar
                document.getElementById('userAktifNama').innerText = userSesiAktif.nama;
                document.getElementById('userAktifShift').innerText = "Shift: " + userSesiAktif.shift;
                
                refreshSistem();
            } else {
                // Tampilkan layer login penuh jika belum masuk
                authContainer.classList.remove('hidden');
                toggleAuthBox(false);
            }
        }

        // --- CORE INVENTORY & KASIR SYSTEM ---
        function refreshSistem() {
            renderGudang();
            renderKasirProduk();
            renderAmbilGudangList();
            renderKeranjang();
            renderHistory();
            hitungUangDanNotif();
        }

        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById('tab-' + tabName).classList.remove('hidden');
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-emerald-600', 'text-white');
                btn.classList.add('text-gray-400');
            });
            document.getElementById('btn-' + tabName).classList.add('bg-emerald-600', 'text-white');
        }

        function cekStatusKritis(item) {
            let hampirHabis = item.stok <= 5;
            let hariIni = new Date();
            let expDate = new Date(item.tglExp);
            let diffDays = Math.ceil((expDate - hariIni) / (1000 * 60 * 60 * 24));
            let hampirExp = diffDays <= 7;

            return { hampirHabis, hampirExp, expired: diffDays < 0, sisaHari: diffDays };
        }

        function aplikasikanWarnaKustom() {
            let mainBg = document.getElementById('customBgColor').value;
            let boxBg = document.getElementById('customBoxColor').value;
            
            document.getElementById('bodyApp').style.backgroundColor = mainBg;
            document.getElementById('sidebarContainer').style.backgroundColor = boxBg;
            
            document.querySelectorAll('.data-box').forEach(box => {
                box.style.backgroundColor = boxBg;
            });
        }

        function gantiTemaPreset(mainBg, boxBg) {
            document.getElementById('customBgColor').value = mainBg;
            document.getElementById('customBoxColor').value = boxBg;
            aplikasikanWarnaKustom();
        }

        function renderGudang() {
            const keyword = document.getElementById('searchGudang').value.toLowerCase();
            const tbody = document.getElementById('tabelGudangBody');
            tbody.innerHTML = '';

            dataBarang.forEach((item, index) => {
                if(item.nama.toLowerCase().includes(keyword)) {
                    let status = cekStatusKritis(item);
                    let totalHargaBarang = item.stok * item.harga;

                    let rowBgClass = (status.hampirHabis || status.hampirExp || status.expired) 
                        ? 'bg-red-950/30 text-red-200 border-red-900/60 hover:bg-red-950/50' 
                        : 'hover:bg-gray-700/30';

                    tbody.innerHTML += `
                        <tr class="${rowBgClass} border-b border-gray-700 transition-colors">
                            <td class="p-4 font-semibold flex items-center gap-2">
                                ${item.nama}
                                ${(status.hampirHabis || status.hampirExp) ? '<span class="bg-red-500 text-white text-[10px] px-1.5 py-0.5 rounded animate-pulse font-bold">KRITIS</span>' : ''}
                            </td>
                            <td class="p-4"><span class="px-2 py-1 rounded text-xs ${status.hampirHabis ? 'bg-red-600 text-white font-bold' : 'bg-gray-700'}">${item.stok} pcs</span></td>
                            <td class="p-4">Rp ${item.harga.toLocaleString('id-ID')}</td>
                            <td class="p-4 font-bold ${status.hampirHabis ? 'text-red-400' : 'text-emerald-400'}">Rp ${totalHargaBarang.toLocaleString('id-ID')}</td>
                            <td class="p-4 text-gray-400">${item.tglMasuk}</td>
                            <td class="p-4 ${status.hampirExp ? 'text-red-400 font-bold' : 'text-gray-400'}">${item.tglExp}</td>
                            <td class="p-4 text-gray-400">${item.pernahAmbil ? '<span class="text-emerald-400 font-medium">Aktif di Kasir</span>' : '<span class="text-amber-400 font-medium">Gudang Only</span>'}</td>
                            <td class="p-4">
                                <div class="flex gap-2 justify-center">
                                    <button onclick="openModal('edit', ${index})" class="text-blue-400 hover:text-blue-300 p-1 cursor-pointer transition-colors"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                                    <button onclick="hapusBarang(${index})" class="text-red-400 hover:text-red-300 p-1 cursor-pointer transition-colors"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                                </div>
                            </td>
                        </tr>
                    `;
                }
            });
            lucide.createIcons();
        }

        function renderKasirProduk() {
            const keyword = document.getElementById('searchKasir').value.toLowerCase();
            const grid = document.getElementById('kasirProdukGrid');
            grid.innerHTML = '';

            let counterBarangTampil = 0;

            dataBarang.forEach((item, index) => {
                if(item.pernahAmbil && item.nama.toLowerCase().includes(keyword)) {
                    counterBarangTampil++;
                    let status = cekStatusKritis(item);
                    let boxColor = (status.hampirHabis || status.hampirExp || status.expired)
                        ? 'bg-gradient-to-r from-red-950/50 to-red-900/40 border-red-500/50 text-red-100'
                        : 'bg-gray-700/60 border-gray-600';

                    grid.innerHTML += `
                        <div class="${boxColor} p-4 rounded-xl border flex justify-between items-center transition-all shadow-md">
                            <div>
                                <h4 class="font-bold flex items-center gap-1.5">
                                    ${item.nama}
                                    ${status.hampirHabis ? '<span class="text-[9px] bg-red-600 text-white px-1.5 py-0.5 rounded">Stok Tipis</span>' : ''}
                                </h4>
                                <p class="text-xs text-gray-300 mt-1">Sisa Kasir: <b class="${status.hampirHabis ? 'text-yellow-400':''}">${item.stok} pcs</b> | Rp ${item.harga.toLocaleString('id-ID')}</p>
                                <p class="text-[10px] text-gray-400">Exp: ${item.tglExp}</p>
                            </div>
                            <button onclick="tambahKeKeranjang(${index})" class="bg-emerald-500 hover:bg-emerald-600 text-gray-950 p-2 rounded-lg cursor-pointer transition-all">
                                <i data-lucide="plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                    `;
                }
            });

            if(counterBarangTampil === 0) {
                grid.innerHTML = '<p class="text-gray-500 italic text-sm col-span-1 sm:col-span-2 text-center py-8">Belum ada barang yang diambil dari gudang atau kata kunci salah.</p>';
            }
            lucide.createIcons();
        }

        function renderAmbilGudangList() {
            const keyword = document.getElementById('searchAmbilGudang').value.toLowerCase();
            const container = document.getElementById('ambilGudangResultList');
            container.innerHTML = '';

            if(!keyword) {
                container.innerHTML = '<p class="text-gray-500 italic text-[11px]">Ketik nama untuk mencari stok di gudang...</p>';
                return;
            }

            dataBarang.forEach((item, index) => {
                if(item.nama.toLowerCase().includes(keyword)) {
                    let status = cekStatusKritis(item);
                    let barColor = (status.hampirHabis || status.hampirExp) ? 'border-red-500 bg-red-950/20' : 'border-gray-600';

                    container.innerHTML += `
                        <div class="p-2.5 rounded border ${barColor} flex justify-between items-center bg-gray-700/50">
                            <div>
                                <span class="font-semibold block text-gray-200 text-xs">${item.nama}</span>
                                <span class="text-[10px] ${item.pernahAmbil ? 'text-emerald-400':'text-amber-400'}">${item.pernahAmbil ? 'Sudah di etalase':'Belum di etalase'}</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <input type="number" id="qtyAmbil-${index}" value="10" min="1" class="w-12 bg-gray-800 text-center text-white border border-gray-600 rounded text-xs p-1 focus:outline-none">
                                <button onclick="ambilDariGudangKeKasir(${index})" class="bg-amber-500 hover:bg-amber-600 text-gray-950 px-2.5 py-1 rounded text-[10px] font-bold cursor-pointer transition-all">
                                    Ambil
                                </button>
                            </div>
                        </div>
                    `;
                }
            });
        }

        function ambilDariGudangKeKasir(index) {
            let inputQty = document.getElementById(`qtyAmbil-${index}`);
            let jumlahAmbil = parseInt(inputQty.value) || 0;
            if(jumlahAmbil <= 0) return alert("Jumlah pengambilan minimal 1 pcs!");

            dataBarang[index].stok += jumlahAmbil;
            dataBarang[index].keluar += jumlahAmbil;
            dataBarang[index].pernahAmbil = true;

            alert(`Sukses! ${jumlahAmbil} pcs [${dataBarang[index].nama}] berhasil dipindahkan ke etalase kasir.`);
            document.getElementById('searchAmbilGudang').value = '';
            refreshSistem();
        }

        function tambahKeKeranjang(index) {
            const produk = dataBarang[index];
            if(produk.stok <= 0) return alert("Stok di etalase kasir habis! Ambil kembali dari gudang belakang.");
            
            const itemKeranjang = keranjang.find(item => item.indexBarang === index);
            if(itemKeranjang) {
                if(itemKeranjang.qty < produk.stok) {
                    itemKeranjang.qty++;
                } else {
                    alert("Stok di etalase kasir tidak mencukupi!");
                }
            } else {
                keranjang.push({ indexBarang: index, nama: produk.nama, harga: produk.harga, qty: 1 });
            }
            renderKeranjang();
        }

        function renderKeranjang() {
            const list = document.getElementById('keranjangList');
            list.innerHTML = '';
            totalTagihanGlobal = 0;

            keranjang.forEach((item, index) => {
                totalTagihanGlobal += item.harga * item.qty;
                list.innerHTML += `
                    <div class="flex justify-between items-center bg-gray-700/60 p-2.5 rounded-lg text-xs border border-gray-600">
                        <div>
                            <p class="font-bold text-gray-100">${item.nama}</p>
                            <p class="text-gray-400">${item.qty} x Rp ${item.harga.toLocaleString('id-ID')}</p>
                        </div>
                        <button onclick="hapusKeranjang(${index})" class="text-red-400 hover:text-red-300 cursor-pointer p-1 transition-colors">
                            <i data-lucide="x-circle" class="w-4 h-4"></i>
                        </button>
                    </div>
                `;
            });

            if (keranjang.length === 0) {
                list.innerHTML = '<p class="text-gray-500 italic text-center py-4">Keranjang kosong.</p>';
            }

            document.getElementById('totalTagihan').innerText = "Rp " + totalTagihanGlobal.toLocaleString('id-ID');
            hitungKembalian();
            lucide.createIcons();
        }

        function hitungKembalian() {
            let tunai = parseInt(document.getElementById('uangBayarInput').value) || 0;
            let kembalian = tunai - totalTagihanGlobal;

            if (totalTagihanGlobal === 0) {
                document.getElementById('uangKembalianText').innerText = "Rp 0";
                return;
            }

            if(kembalian < 0) {
                document.getElementById('uangKembalianText').innerText = "Uang Kurang";
            } else {
                document.getElementById('uangKembalianText').innerText = "Rp " + kembalian.toLocaleString('id-ID');
            }
        }

        function hapusKeranjang(index) {
            keranjang.splice(index, 1);
            renderKeranjang();
        }

        function bayarTransaksi() {
            if(keranjang.length === 0) return alert("Keranjang belanja kosong!");
            let tunai = parseInt(document.getElementById('uangBayarInput').value) || 0;
            if(tunai < totalTagihanGlobal) return alert("Pembayaran gagal! Uang tunai yang diterima kurang.");

            let idTrans = "TRX-" + Math.floor(Math.random() * 90000 + 10000);
            let waktu = new Date().toLocaleString('id-ID');

            keranjang.forEach(item => {
                dataBarang[item.indexBarang].stok -= item.qty;
                historyPenjualan.push({
                    waktu: waktu,
                    id: idTrans,
                    nama: item.nama,
                    qty: item.qty,
                    total: item.harga * item.qty
                });
                omsetPenjualan += (item.harga * item.qty);
                uangKas += (item.harga * item.qty);
            });

            alert(`Transaksi berhasil! Id: ${idTrans}. Kembalian: Rp ${(tunai - totalTagihanGlobal).toLocaleString('id-ID')}`);
            keranjang = [];
            document.getElementById('uangBayarInput').value = '';
            refreshSistem();
        }

        function renderHistory() {
            const keyword = document.getElementById('searchHistory').value.toLowerCase();
            const tbody = document.getElementById('tabelHistoryBody');
            tbody.innerHTML = '';

            historyPenjualan.forEach((item, index) => {
                if(item.nama.toLowerCase().includes(keyword) || item.id.toLowerCase().includes(keyword)) {
                    tbody.innerHTML += `
                        <tr class="hover:bg-gray-700/30 transition-colors">
                            <td class="p-4 text-gray-400">${item.waktu}</td>
                            <td class="p-4 font-mono text-emerald-400 font-semibold">${item.id}</td>
                            <td class="p-4 font-bold">${item.nama}</td>
                            <td class="p-4">${item.qty} pcs</td>
                            <td class="p-4 font-semibold text-emerald-400">Rp ${item.total.toLocaleString('id-ID')}</td>
                            <td class="p-4">
                                <div class="flex justify-center">
                                    <button onclick="hapusHistory(${index})" class="text-red-400 hover:text-red-300 p-1 cursor-pointer transition-colors">
                                        <i data-lucide="trash-2" class="w-4 h-4"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `;
                }
            });
            lucide.createIcons();
        }

        function hapusHistory(index) {
            if(confirm("Apakah Anda yakin ingin menghapus data riwayat transaksi ini?")) {
                historyPenjualan.splice(index, 1);
                renderHistory();
            }
        }

        function hitungUangDanNotif() {
            totalAsetSekarang = 0;
            dataBarang.forEach(item => {
                totalAsetSekarang += (item.stok * item.harga);
            });

            document.getElementById('dompetSaldo').innerText = "Rp " + uangKas.toLocaleString('id-ID');
            document.getElementById('dompetOmset').innerText = "Rp " + omsetPenjualan.toLocaleString('id-ID');
            document.getElementById('dompetAsetBarang').innerText = "Rp " + totalAsetSekarang.toLocaleString('id-ID');
            document.getElementById('dompetProduk').innerText = dataBarang.length + " SKU";

            const notifPanel = document.getElementById('notifList');
            notifPanel.innerHTML = '';

            dataBarang.forEach(item => {
                if(item.pernahAmbil) {
                    let status = cekStatusKritis(item);
                    if(status.hampirHabis) {
                        notifPanel.innerHTML += `<div class="bg-red-500/10 text-red-400 p-2 rounded border border-red-500/30 font-semibold">⚠️ STOK KASIR TIPIS: ${item.nama} Sisa ${item.stok} pcs!</div>`;
                    }
                    if(status.expired) {
                        notifPanel.innerHTML += `<div class="bg-red-600/20 text-red-500 p-2 rounded border border-red-600/40 font-bold">❌ EXPIRED: ${item.nama} kedaluwarsa!</div>`;
                    }
                }
            });

            if(notifPanel.innerHTML === '') {
                notifPanel.innerHTML = '<p class="text-gray-500 italic text-center py-2">Semua aman, tidak ada peringatan.</p>';
            }
        }

        function setModalManual() {
            const val = document.getElementById('inputModalBaru').value;
            if(!val) return;
            uangKas = parseInt(val);
            document.getElementById('inputModalBaru').value = '';
            refreshSistem();
            alert("Uang kas toko berhasil di-update!");
        }

        function exportGudangExcel() {
            if(dataBarang.length === 0) return alert("Tidak ada data barang di gudang.");
            const dataWS = dataBarang.map(item => ({
                "Nama Barang": item.nama,
                "Stok Aktif Kasir": item.stok,
                "Harga Satuan": item.harga,
                "Status di Kasir": item.pernahAmbil ? "Aktif" : "Belum Diambil",
                "Tanggal Kedaluwarsa": item.tglExp
            }));
            const ws = XLSX.utils.json_to_sheet(dataWS);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Stok_Gudang");
            XLSX.writeFile(wb, "Laporan_Gudang.xlsx");
        }

        function kirimGudangWA() {
            let text = "*LAPORAN STOK GUDANG*\n\n";
            dataBarang.forEach((item, i) => {
                text += `${i+1}. *${item.nama}* | Sisa Kasir: ${item.stok} pcs | [${item.pernahAmbil ? 'Aktif':'Gudang Only'}]\n`;
            });
            window.open("https://api.whatsapp.com/send?text=" + encodeURIComponent(text), '_blank');
        }

        function exportKeuanganExcel() {
            const dataKeuangan = [
                { "Uraian": "Total Saldo Kas Toko", "Nominal": uangKas },
                { "Uraian": "Total Omset Penjualan", "Nominal": omsetPenjualan },
                { "Uraian": "Total Nilai Uang di Barang", "Nominal": totalAsetSekarang }
            ];
            const ws = XLSX.utils.json_to_sheet(dataKeuangan);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Keuangan");
            XLSX.writeFile(wb, "Laporan_Keuangan.xlsx");
        }

        function kirimKeuanganWA() {
            let text = "*LAPORAN RINGKASAN KEUANGAN TOKO*\n\n";
            text += `💰 Kas Toko: Rp ${uangKas.toLocaleString('id-ID')}\n📈 Omset: Rp ${omsetPenjualan.toLocaleString('id-ID')}\n📦 Aset Barang: Rp ${totalAsetSekarang.toLocaleString('id-ID')}\n`;
            window.open("https://api.whatsapp.com/send?text=" + encodeURIComponent(text), '_blank');
        }

        function exportToExcel() {
            if(historyPenjualan.length === 0) return alert("Belum ada history.");
            const ws = XLSX.utils.json_to_sheet(historyPenjualan);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "History");
            XLSX.writeFile(wb, "History_Penjualan.xlsx");
        }

        function kirimWhatsApp() {
            if(historyPenjualan.length === 0) return alert("History kosong.");
            let text = "*HISTORY TRANSAKSI KASIR*\n\n";
            historyPenjualan.forEach((item, i) => {
                text += `${i+1}. [${item.id}] ${item.nama} x ${item.qty}\n`;
            });
            window.open("https://api.whatsapp.com/send?text=" + encodeURIComponent(text), '_blank');
        }

        function openModal(mode, index = null) {
            document.getElementById('formModal').classList.remove('hidden');
            if(mode === 'tambah') {
                document.getElementById('modalTitle').innerText = "Tambah Barang Baru";
                document.getElementById('editIndex').value = "";
                document.getElementById('formNama').value = "";
                document.getElementById('formStok').value = "0";
                document.getElementById('formHarga').value = "";
                document.getElementById('formTglMasuk').value = new Date().toISOString().split('T')[0];
                document.getElementById('formTglExp').value = "";
            } else {
                document.getElementById('modalTitle').innerText = "Edit Data Barang";
                document.getElementById('editIndex').value = index;
                let item = dataBarang[index];
                document.getElementById('formNama').value = item.nama;
                document.getElementById('formStok').value = item.stok;
                document.getElementById('formHarga').value = item.harga;
                document.getElementById('formTglMasuk').value = item.tglMasuk;
                document.getElementById('formTglExp').value = item.tglExp;
            }
        }

        function closeModal() { 
            document.getElementById('formModal').classList.add('hidden'); 
        }

        function simpanBarang() {
            const idx = document.getElementById('editIndex').value;
            const nama = document.getElementById('formNama').value;
            const stok = parseInt(document.getElementById('formStok').value) || 0;
            const harga = parseInt(document.getElementById('formHarga').value) || 0;
            const tglMasuk = document.getElementById('formTglMasuk').value;
            const tglExp = document.getElementById('formTglExp').value;

            if(!nama || !tglExp) return alert("Mohon lengkapi data!");

            if(idx === "") {
                dataBarang.push({ nama, stok, harga, tglMasuk, tglExp, keluar: 0, pernahAmbil: stok > 0 });
            } else {
                dataBarang[idx].nama = nama;
                dataBarang[idx].stok = stok;
                dataBarang[idx].harga = harga;
                dataBarang[idx].tglMasuk = tglMasuk;
                dataBarang[idx].tglExp = tglExp;
            }
            closeModal();
            refreshSistem();
        }

        function hapusBarang(index) {
            if(confirm("Apakah Anda yakin ingin menghapus produk ini dari database?")) {
                dataBarang.splice(index, 1);
                refreshSistem();
            }
        }
    </script>
</body>
</html>
