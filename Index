<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistem Manajemen Toko & Gudang Premium</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
</head>
<body class="bg-gray-900 text-gray-100 min-h-screen font-sans transition-colors duration-300" id="bodyApp">

    <div class="flex h-screen overflow-hidden">
        <div class="w-64 bg-gray-800 border-r border-gray-700 flex flex-col justify-between">
            <div class="p-5">
                <h1 class="text-xl font-bold tracking-wider text-emerald-400 flex items-center gap-2">
                    <i data-lucide="store"></i> TOKO & GUDANG
                </h1>
                <nav class="mt-8 space-y-2">
                    <button onclick="switchTab('gudang')" id="btn-gudang" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg bg-emerald-600 text-white font-medium transition-all">
                        <i data-lucide="warehouse"></i> Gudang Belakang
                    </button>
                    <button onclick="switchTab('kasir')" id="btn-kasir" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all">
                        <i data-lucide="shopping-cart"></i> Kasir / Penjualan
                    </button>
                    <button onclick="switchTab('history')" id="btn-history" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all">
                        <i data-lucide="history"></i> History Penjualan
                    </button>
                    <button onclick="switchTab('keuangan')" id="btn-keuangan" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all">
                        <i data-lucide="wallet"></i> Manajemen Keuangan
                    </button>
                    <button onclick="switchTab('setting')" id="btn-setting" class="tab-btn w-full flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:bg-gray-700 hover:text-white transition-all">
                        <i data-lucide="settings"></i> Pengaturan Tema
                    </button>
                </nav>
            </div>
            
            <div class="p-4 bg-gray-850 border-t border-gray-700 max-h-48 overflow-y-auto" id="sidebarNotif">
                <span class="text-xs font-semibold text-gray-400 uppercase tracking-wider block mb-2">Notifikasi Sistem</span>
                <div id="notifList" class="space-y-2 text-xs">
                    </div>
            </div>
        </div>

        <div class="flex-1 flex flex-col overflow-y-auto p-8">
            
            <div id="tab-gudang" class="tab-content space-y-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h2 class="text-2xl font-bold">Gudang Belakang (Stok Produk)</h2>
                        <p class="text-gray-400 text-sm">Kelola seluruh stok masuk, keluar, dan kedaluwarsa produk.</p>
                    </div>
                    <button onclick="openModal('tambah')" class="bg-emerald-500 hover:bg-emerald-600 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow-lg">
                        <i data-lucide="plus-circle"></i> Tambah Barang
                    </button>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 flex items-center gap-3">
                    <i data-lucide="search" class="text-gray-400"></i>
                    <input type="text" id="searchGudang" oninput="renderGudang()" placeholder="Cari berdasarkan nama produk di gudang..." class="bg-transparent w-full focus:outline-none text-white">
                </div>

                <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-md">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-750 text-gray-300 text-sm border-b border-gray-700">
                                <th class="p-4">Nama Barang</th>
                                <th class="p-4">Stok</th>
                                <th class="p-4">Harga Jual</th>
                                <th class="p-4">Tgl Masuk</th>
                                <th class="p-4">Tgl Expired</th>
                                <th class="p-4">Barang Keluar</th>
                                <th class="p-4 text-center">Aksi</th>
                            </tr>
                        </thead>
                        <tbody id="tabelGudangBody" class="divide-y divide-gray-700 text-sm">
                            </tbody>
                    </table>
                </div>
            </div>

            <div id="tab-kasir" class="tab-content hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold">Kasir Penjualan</h2>
                    <p class="text-gray-400 text-sm">Layani transaksi penjualan dengan cepat.</p>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <div class="col-span-2 bg-gray-800 p-6 rounded-xl border border-gray-700 space-y-4">
                        <div class="bg-gray-700 p-3 rounded-lg flex items-center gap-3">
                            <i data-lucide="search" class="text-gray-400"></i>
                            <input type="text" id="searchKasir" oninput="renderKasirProduk()" placeholder="Cari produk siap jual..." class="bg-transparent w-full focus:outline-none text-white">
                        </div>
                        <div class="grid grid-cols-2 gap-4 max-h-[400px] overflow-y-auto pr-2" id="kasirProdukGrid">
                            </div>
                    </div>
                    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 flex flex-col justify-between h-[500px]">
                        <div>
                            <h3 class="font-bold text-lg border-b border-gray-700 pb-2 mb-3 flex items-center gap-2">
                                <i data-lucide="shopping-bag" class="text-emerald-400"></i> Keranjang Belanja
                            </h3>
                            <div class="space-y-3 max-h-[250px] overflow-y-auto pr-2" id="keranjangList">
                                </div>
                        </div>
                        <div class="border-t border-gray-700 pt-4 space-y-4">
                            <div class="flex justify-between items-center text-xl font-bold">
                                <span>Total Tagihan:</span>
                                <span class="text-emerald-400" id="totalTagihan">Rp 0</span>
                            </div>
                            <button onclick="bayarTransaksi()" class="w-full bg-emerald-500 hover:bg-emerald-600 py-3 rounded-xl font-bold shadow-lg transition-all cursor-pointer text-center">
                                Selesaikan Transaksi & Potong Stok
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="tab-history" class="tab-content hidden space-y-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h2 class="text-2xl font-bold">Riwayat Penjualan (History)</h2>
                        <p class="text-gray-400 text-sm">Laporan riwayat transaksi keluar barang yang terjual.</p>
                    </div>
                    <div class="flex gap-2">
                        <button onclick="exportToExcel()" class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow">
                            <i data-lucide="file-spreadsheet"></i> Export Excel
                        </button>
                        <button onclick="kirimWhatsApp()" class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2 cursor-pointer shadow">
                            <i data-lucide="share-2"></i> Kirim WA (08991286742)
                        </button>
                    </div>
                </div>

                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 flex items-center gap-3">
                    <i data-lucide="search" class="text-gray-400"></i>
                    <input type="text" id="searchHistory" oninput="renderHistory()" placeholder="Cari data history berdasarkan nama barang atau ID Transaksi..." class="bg-transparent w-full focus:outline-none text-white">
                </div>

                <div class="bg-gray-800 rounded-xl border border-gray-700 overflow-hidden shadow-md">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-gray-750 text-gray-300 text-sm border-b border-gray-700">
                                <th class="p-4">Waktu Transaksi</th>
                                <th class="p-4">ID Transaksi</th>
                                <th class="p-4">Nama Barang</th>
                                <th class="p-4">Jumlah Terjual</th>
                                <th class="p-4">Total Pendapatan</th>
                            </tr>
                        </thead>
                        <tbody id="tabelHistoryBody" class="divide-y divide-gray-700 text-sm">
                            </tbody>
                    </table>
                </div>
            </div>

            <div id="tab-keuangan" class="tab-content hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold">Manajemen Keuangan</h2>
                    <p class="text-gray-400 text-sm">Pantau total modal arus kas dan laba bersih penjualan toko Anda.</p>
                </div>

                <div class="grid grid-cols-3 gap-6">
                    <div class="bg-gradient-to-br from-emerald-600 to-teal-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Saldo Kas Toko</span>
                            <i data-lucide="wallet"></i>
                        </div>
                        <h3 class="text-3xl font-extrabold tracking-tight" id="dompetSaldo">Rp 2.500.000</h3>
                    </div>
                    <div class="bg-gradient-to-br from-blue-600 to-indigo-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Omset Penjualan</span>
                            <i data-lucide="trending-up"></i>
                        </div>
                        <h3 class="text-3xl font-extrabold tracking-tight" id="dompetOmset">Rp 0</h3>
                    </div>
                    <div class="bg-gradient-to-br from-amber-600 to-orange-700 p-6 rounded-2xl shadow-xl space-y-2">
                        <div class="flex justify-between items-center opacity-80">
                            <span class="font-medium text-sm">Total Macam Produk</span>
                            <i data-lucide="box"></i>
                        </div>
                        <h3 class="text-3xl font-extrabold tracking-tight" id="dompetProduk">0 SKU</h3>
                    </div>
                </div>

                <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 space-y-4">
                    <h3 class="font-bold text-lg">Sesuaikan Modal Kas Manual</h3>
                    <div class="flex gap-4">
                        <input type="number" id="inputModalBaru" placeholder="Masukkan jumlah uang/modal awal..." class="bg-gray-700 border border-gray-600 rounded-lg px-4 py-2 w-72 text-white focus:outline-none focus:border-emerald-500">
                        <button onclick="setModalManual()" class="bg-emerald-500 hover:bg-emerald-600 px-6 py-2 rounded-lg font-semibold cursor-pointer">Simpan Uang Kas</button>
                    </div>
                </div>
            </div>

            <div id="tab-setting" class="tab-content hidden space-y-6">
                <div>
                    <h2 class="text-2xl font-bold">Pengaturan Warna Background</h2>
                    <p class="text-gray-400 text-sm">Ubah tampilan dashboard aplikasi sesuai kenyamanan mata Anda.</p>
                </div>

                <div class="grid grid-cols-4 gap-4">
                    <button onclick="gantiTema('bg-gray-900', 'bg-gray-800', 'text-gray-100')" class="p-6 border-2 border-emerald-500 rounded-xl bg-gray-900 text-left space-y-2 cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-emerald-500"></div>
                        <span class="font-semibold block">Midnight Dark (Bawaan)</span>
                    </button>
                    <button onclick="gantiTema('bg-slate-900', 'bg-slate-800', 'text-slate-100')" class="p-6 border border-gray-700 rounded-xl bg-slate-900 text-left space-y-2 cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-blue-500"></div>
                        <span class="font-semibold block">Deep Slate Blue</span>
                    </button>
                    <button onclick="gantiTema('bg-zinc-950', 'bg-zinc-900', 'text-zinc-100')" class="p-6 border border-gray-700 rounded-xl bg-zinc-950 text-left space-y-2 cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-zinc-500"></div>
                        <span class="font-semibold block">Pitch Black AMOLED</span>
                    </button>
                    <button onclick="gantiTema('bg-emerald-950', 'bg-emerald-900', 'text-emerald-50')" class="p-6 border border-gray-700 rounded-xl bg-emerald-950 text-left space-y-2 cursor-pointer">
                        <div class="w-8 h-8 rounded-full bg-teal-500"></div>
                        <span class="font-semibold block">Forest Green Mood</span>
                    </button>
                </div>
            </div>

        </div>
    </div>

    <div id="formModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center p-4 z-50">
        <div class="bg-gray-800 border border-gray-700 rounded-2xl w-full max-w-lg p-6 shadow-2xl space-y-4">
            <h3 id="modalTitle" class="text-xl font-bold text-emerald-400">Tambah Barang Baru</h3>
            <input type="hidden" id="editIndex">
            
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Nama Barang</label>
                    <input type="text" id="formNama" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Jumlah Stok (Gudang)</label>
                    <input type="number" id="formStok" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Harga Jual (Rp)</label>
                    <input type="number" id="formHarga" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Tanggal Masuk</label>
                    <input type="date" id="formTglMasuk" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500">
                </div>
                <div>
                    <label class="text-xs text-gray-400 font-semibold block mb-1">Tanggal Expiry (Kadaluwarsa)</label>
                    <input type="date" id="formTglExp" class="w-full bg-gray-700 border border-gray-600 rounded-lg p-2 focus:outline-none focus:border-emerald-500">
                </div>
            </div>

            <div class="flex justify-end gap-2 pt-4 border-t border-gray-700">
                <button onclick="closeModal()" class="px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 font-semibold cursor-pointer text-sm">Batal</button>
                <button onclick="simpanBarang()" class="px-4 py-2 rounded-lg bg-emerald-500 hover:bg-emerald-600 font-semibold cursor-pointer text-sm">Simpan Data</button>
            </div>
        </div>
    </div>

    <script>
        // DUMMY DATA AWAL (Auto Load)
        let dataBarang = [
            { nama: "Susu UHT Frisian", stok: 12, harga: 6500, tglMasuk: "2026-01-01", tglExp: "2026-07-10", keluar: 0, terjual: 0 },
            { nama: "Mie Instan Goreng", stok: 4, harga: 3500, tglMasuk: "2026-02-15", tglExp: "2027-05-20", keluar: 0, terjual: 0 },
            { nama: "Roti Tawar Kupas", stok: 20, harga: 15000, tglMasuk: "2026-03-01", tglExp: "2026-07-06", keluar: 0, terjual: 0 }
        ];

        let historyPenjualan = [];
        let uangKas = 2500000;
        let omsetPenjualan = 0;
        let keranjang = [];

        // Inisialisasi awal saat halaman dibuka
        window.onload = function() {
            lucide.createIcons();
            refreshSistem();
        }

        function refreshSistem() {
            renderGudang();
            renderKasirProduk();
            renderKeranjang();
            renderHistory();
            hitungUangDanNotif();
        }

        // TAB SWITCHER EFFECT
        function switchTab(tabName) {
            document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
            document.getElementById('tab-' + tabName).classList.remove('hidden');
            
            document.querySelectorAll('.tab-btn').forEach(btn => {
                btn.classList.remove('bg-emerald-600', 'text-white');
                btn.classList.add('text-gray-400');
            });
            document.getElementById('btn-' + tabName).classList.add('bg-emerald-600', 'text-white');
        }

        // RENDER DATA GUDANG + FITUR PENCARIAN GUDANG
        function renderGudang() {
            const keyword = document.getElementById('searchGudang').value.toLowerCase();
            const tbody = document.getElementById('tabelGudangBody');
            tbody.innerHTML = '';

            dataBarang.forEach((item, index) => {
                if(item.nama.toLowerCase().includes(keyword)) {
                    tbody.innerHTML += `
                        <tr class="hover:bg-gray-750/50">
                            <td class="p-4 font-semibold">${item.nama}</td>
                            <td class="p-4"><span class="px-2 py-1 rounded text-xs ${item.stok <= 5 ? 'bg-red-500/20 text-red-400 font-bold':'bg-gray-700'}">${item.stok} pcs</span></td>
                            <td class="p-4">Rp ${item.harga.toLocaleString('id-ID')}</td>
                            <td class="p-4 text-gray-400">${item.tglMasuk}</td>
                            <td class="p-4 text-gray-400">${item.tglExp}</td>
                            <td class="p-4 text-gray-400">${item.keluar} pcs</td>
                            <td class="p-4 flex gap-2 justify-center">
                                <button onclick="openModal('edit', ${index})" class="text-blue-400 hover:text-blue-300 p-1 cursor-pointer"><i data-lucide="edit-3" class="w-4 h-4"></i></button>
                                <button onclick="hapusBarang(${index})" class="text-red-400 hover:text-red-300 p-1 cursor-pointer"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                            </td>
                        </tr>
                    `;
                }
            });
            lucide.createIcons();
        }

        // RENDER KASIR + FITUR PENCARIAN KASIR
        function renderKasirProduk() {
            const keyword = document.getElementById('searchKasir').value.toLowerCase();
            const grid = document.getElementById('kasirProdukGrid');
            grid.innerHTML = '';

            dataBarang.forEach((item, index) => {
                if(item.nama.toLowerCase().includes(keyword) && item.stok > 0) {
                    grid.innerHTML += `
                        <div class="bg-gray-700 p-4 rounded-xl border border-gray-600 flex justify-between items-center">
                            <div>
                                <h4 class="font-bold">${item.nama}</h4>
                                <p class="text-xs text-gray-400">Sisa Stok: ${item.stok} | Rp ${item.harga.toLocaleString('id-ID')}</p>
                            </div>
                            <button onclick="tambahKeKeranjang(${index})" class="bg-emerald-500 hover:bg-emerald-600 p-2 rounded-lg cursor-pointer">
                                <i data-lucide="plus" class="w-4 h-4"></i>
                            </button>
                        </div>
                    `;
                }
            });
            lucide.createIcons();
        }

        // MANAJEMEN KERANJANG KASIR
        function tambahKeKeranjang(index) {
            const produk = dataBarang[index];
            const itemKeranjang = keranjang.find(item => item.indexBarang === index);
            
            if(itemKeranjang) {
                if(itemKeranjang.qty < produk.stok) {
                    itemKeranjang.qty++;
                } else {
                    alert("Stok di gudang tidak mencukupi!");
                }
            } else {
                keranjang.push({ indexBarang: index, nama: produk.nama, harga: produk.harga, qty: 1 });
            }
            renderKeranjang();
        }

        function renderKeranjang() {
            const list = document.getElementById('keranjangList');
            list.innerHTML = '';
            let total = 0;

            keranjang.forEach((item, index) => {
                total += item.harga * item.qty;
                list.innerHTML += `
                    <div class="flex justify-between items-center bg-gray-700/50 p-2 rounded-lg text-xs">
                        <div>
                            <p class="font-bold">${item.nama}</p>
                            <p class="text-gray-400">${item.qty} x Rp ${item.harga}</p>
                        </div>
                        <button onclick="hapusKeranjang(${index})" class="text-red-400 hover:text-red-300 cursor-pointer">
                            <i data-lucide="x-circle" class="w-4 h-4"></i>
                        </button>
                    </div>
                `;
            });
            document.getElementById('totalTagihan').innerText = "Rp " + total.toLocaleString('id-ID');
            lucide.createIcons();
        }

        function hapusKeranjang(index) {
            keranjang.splice(index, 1);
            renderKeranjang();
        }

        // SELESAIKAN TRANSAKSI (POTONG STOK & MASUK KEUANGAN)
        function bayarTransaksi() {
            if(keranjang.length === 0) return alert("Keranjang masih kosong!");
            
            let idTrans = "TRX-" + Math.floor(Math.random() * 90000 + 10000);
            let waktu = new Date().toLocaleString('id-ID');

            keranjang.forEach(item => {
                // Potong Stok Gudang & Tambah Log Terjual/Keluar
                dataBarang[item.indexBarang].stok -= item.qty;
                dataBarang[item.indexBarang].keluar += item.qty;
                dataBarang[item.indexBarang].terjual += item.qty;

                // Masuk Ke History Penjualan
                historyPenjualan.push({
                    waktu: waktu,
                    id: idTrans,
                    nama: item.nama,
                    qty: item.qty,
                    total: item.harga * item.qty
                });

                // Tambah keuangan
                omsetPenjualan += (item.harga * item.qty);
                uangKas += (item.harga * item.qty);
            });

            keranjang = [];
            alert("Transaksi Sukses!");
            refreshSistem();
        }

        // RENDER HISTORY & FITUR PENCARIAN HISTORY
        function renderHistory() {
            const keyword = document.getElementById('searchHistory').value.toLowerCase();
            const tbody = document.getElementById('tabelHistoryBody');
            tbody.innerHTML = '';

            historyPenjualan.forEach(item => {
                if(item.nama.toLowerCase().includes(keyword) || item.id.toLowerCase().includes(keyword)) {
                    tbody.innerHTML += `
                        <tr class="hover:bg-gray-750/50">
                            <td class="p-4 text-gray-400">${item.waktu}</td>
                            <td class="p-4 font-mono text-emerald-400 font-semibold">${item.id}</td>
                            <td class="p-4 font-bold">${item.nama}</td>
                            <td class="p-4">${item.qty} pcs</td>
                            <td class="p-4 font-semibold text-emerald-400">Rp ${item.total.toLocaleString('id-ID')}</td>
                        </tr>
                    `;
                }
            });
        }

        // MANAJEMEN NOTIFIKASI OTOMATIS & DASHBOARD DOMPET KEUANGAN
        function hitungUangDanNotif() {
            document.getElementById('dompetSaldo').innerText = "Rp " + uangKas.toLocaleString('id-ID');
            document.getElementById('dompetOmset').innerText = "Rp " + omsetPenjualan.toLocaleString('id-ID');
            document.getElementById('dompetProduk').innerText = dataBarang.length + " SKU";

            const notifPanel = document.getElementById('notifList');
            notifPanel.innerHTML = '';

            let hariIni = new Date();

            dataBarang.forEach(item => {
                // 1. Notif Hampir Habis (Stok <= 5)
                if(item.stok <= 5) {
                    notifPanel.innerHTML += `
                        <div class="bg-red-500/10 text-red-400 p-2 rounded border border-red-500/30">
                            ⚠️ <b>${item.nama}</b> hampir habis! Sisa <b>${item.stok}</b>.
                        </div>
                    `;
                }

                // 2. Notif Hampir Expired (Kurang dari 7 hari dari sekarang)
                let expDate = new Date(item.tglExp);
                let diffTime = expDate - hariIni;
                let diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                if(diffDays <= 7 && diffDays >= 0) {
                    notifPanel.innerHTML += `
                        <div class="bg-amber-500/10 text-amber-400 p-2 rounded border border-amber-500/30">
                            ⏳ <b>${item.nama}</b> mau Expired dalam <b>${diffDays} hari lagi</b> (${item.tglExp}).
                        </div>
                    `;
                } else if (diffDays < 0) {
                    notifPanel.innerHTML += `
                        <div class="bg-red-600/20 text-red-500 p-2 rounded border border-red-600/40 font-bold">
                            ❌ <b>${item.nama}</b> SUDAH EXPIRED!
                        </div>
                    `;
                }
            });

            if(notifPanel.innerHTML === '') {
                notifPanel.innerHTML = '<p class="text-gray-500 italic">Semua aman, tidak ada peringatan.</p>';
            }
        }

        // SET MODAL MANUAL KEUANGAN
        function setModalManual() {
            const val = document.getElementById('inputModalBaru').value;
            if(!val) return;
            uangKas = parseInt(val);
            document.getElementById('inputModalBaru').value = '';
            refreshSistem();
            alert("Uang kas toko berhasil di-update!");
        }

        // EXPORT DATA KE EXCEL (SheetJS)
        function exportToExcel() {
            if(historyPenjualan.length === 0) return alert("Belum ada data history untuk di-export!");
            const dataWS = historyPenjualan.map(item => ({
                "Waktu Transaksi": item.waktu,
                "ID Transaksi": item.id,
                "Nama Barang": item.nama,
                "Jumlah Terjual (Qty)": item.qty,
                "Total Pendapatan (Rp)": item.total
            }));
            
            const ws = XLSX.utils.json_to_sheet(dataWS);
            const wb = XLSX.utils.book_new();
            XLSX.utils.book_append_sheet(wb, ws, "Laporan_Penjualan");
            XLSX.writeFile(wb, "Laporan_Penjualan_Toko.xlsx");
        }

        // KIRIM WHATSAPP FORMAT DATA DOKUMEN SIAP KIRIM
        function kirimWhatsApp() {
            if(historyPenjualan.length === 0) return alert("History kosong, tidak ada data untuk dikirim.");
            
            let text = "*LAPORAN DOKUMEN PENJUALAN TOKO*\n\n";
            historyPenjualan.forEach((item, i) => {
                text += `${i+1}. [${item.id}] *${item.nama}* - ${item.qty} pcs (Total: Rp ${item.total})\n`;
            });
            text += `\n*Total Pendapatan Toko:* Rp ${omsetPenjualan.toLocaleString('id-ID')}`;
            
            let url = "https://api.whatsapp.com/send?phone=628991286742&text=" + encodeURIComponent(text);
            window.open(url, '_blank');
        }

        // FITUR PENGATURAN WARNA BACKGROUND TEMA
        function gantiTema(bg, panel, text) {
            const body = document.getElementById('bodyApp');
            body.className = `${bg} ${text} min-h-screen font-sans transition-colors duration-300`;
            
            // Ubah box pendukung
            document.querySelectorAll('.tab-content table, .bg-gray-800').forEach(box => {
                box.style.backgroundColor = bg === 'bg-zinc-950' ? '#18181b' : (bg === 'bg-emerald-950' ? '#064e3b' : '#1f2937');
            });
        }

        // MODAL INPUT (TAMBAH & EDIT) CONTROL
        function openModal(mode, index = null) {
            document.getElementById('formModal').classList.remove('hidden');
            if(mode === 'tambah') {
                document.getElementById('modalTitle').innerText = "Tambah Barang Baru";
                document.getElementById('editIndex').value = "";
                document.getElementById('formNama').value = "";
                document.getElementById('formStok').value = "";
                document.getElementById('formHarga').value = "";
                document.getElementById('formTglMasuk').value = new Date().toISOString().split('T')[0];
                document.getElementById('formTglExp').value = "";
            } else {
                document.getElementById('modalTitle').innerText = "Edit Data Barang";
                document.getElementById('editIndex').value = index;
                let item = dataBarang[index];
                document.getElementById('formNama').value = item.nama;
                document.getElementById('formStok').value = item.stok;
                document.getElementById('formHarga').value = item.harga;
                document.getElementById('formTglMasuk').value = item.tglMasuk;
                document.getElementById('formTglExp').value = item.tglExp;
            }
        }

        function closeModal() {
            document.getElementById('formModal').classList.add('hidden');
        }

        function simpanBarang() {
            const idx = document.getElementById('editIndex').value;
            const nama = document.getElementById('formNama').value;
            const stok = parseInt(document.getElementById('formStok').value) || 0;
            const harga = parseInt(document.getElementById('formHarga').value) || 0;
            const tglMasuk = document.getElementById('formTglMasuk').value;
            const tglExp = document.getElementById('formTglExp').value;

            if(!nama || !tglExp) return alert("Mohon lengkapi Nama Barang dan Tanggal Expired!");

            if(idx === "") {
                // Tambah Baru
                dataBarang.push({ nama, stok, harga, tglMasuk, tglExp, keluar: 0, terjual: 0 });
            } else {
                // Edit Lama
                dataBarang[idx].nama = nama;
                dataBarang[idx].stok = stok;
                dataBarang[idx].harga = harga;
                dataBarang[idx].tglMasuk = tglMasuk;
                dataBarang[idx].tglExp = tglExp;
            }
            closeModal();
            refreshSistem();
        }

        function hapusBarang(index) {
            if(confirm("Apakah Anda yakin ingin menghapus barang ini dari database gudang?")) {
                dataBarang.splice(index, 1);
                refreshSistem();
            }
        }
    </script>
</body>
</html>
